{
  "name": "gamehub-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "start:backend": "npm run start --workspace=backend",
    "start:backend:dev": "npm run start:dev --workspace=backend",
    "start:frontend:dev": "npm run dev --workspace=frontend",
    "dev": "npm run start:backend:dev & npm run start:frontend:dev"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3"
  }
}
